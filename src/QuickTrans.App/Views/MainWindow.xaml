<Window x:Class="QuickTrans.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:infra="clr-namespace:QuickTrans.App.Infrastructure"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="QuickTrans"
        Width="240"
        SizeToContent="WidthAndHeight"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True"
        WindowStartupLocation="Manual"
        WindowStyle="None">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <infra:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
  </Window.Resources>

  <Grid x:Name="WindowRoot" PreviewMouseLeftButtonDown="WindowRoot_OnPreviewMouseLeftButtonDown">
    <Border Margin="12"
            Background="#FFFDFB"
            BorderBrush="#FFE2E8F0"
            BorderThickness="1"
            CornerRadius="20"
            Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
      <Border.Effect>
        <DropShadowEffect BlurRadius="24"
                          Color="#3B0F172A"
                          Direction="270"
                          Opacity="0.22"
                          ShadowDepth="10" />
      </Border.Effect>

      <Grid Width="220">
        <Grid.RowDefinitions>
          <RowDefinition Height="16" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="Transparent"
                Cursor="SizeAll"
                MouseLeftButtonDown="DragHandle_OnMouseLeftButtonDown">
          <Border HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Width="52"
                  Height="5"
                  Background="#FFD6DCE5"
                  CornerRadius="3" />
        </Border>

        <Border Grid.Row="1" Padding="12,8,12,10">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="8" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputTextBox"
                     Grid.Column="0"
                     MinWidth="120"
                     Background="Transparent"
                     BorderThickness="0"
                     FontFamily="Segoe UI"
                     FontSize="16"
                     Foreground="#FF0F172A"
                     KeyDown="InputTextBox_OnKeyDown"
                     GotKeyboardFocus="InputTextBox_OnGotKeyboardFocus"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" />

            <Button Grid.Column="2"
                    Width="40"
                    Height="40"
                    Background="#FF111827"
                    BorderThickness="0"
                    Command="{Binding TranslateCommand}"
                    Cursor="Hand"
                    FontFamily="Segoe UI"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#FFF8FAFC">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border Background="{TemplateBinding Background}" CornerRadius="12">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                </ControlTemplate>
              </Button.Template>
              <TextBlock Text="译" />
            </Button>
          </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="12,0,12,12"
                Padding="12"
                Background="#FFF8FAFC"
                BorderBrush="#FFE2E8F0"
                BorderThickness="1"
                CornerRadius="16"
                Visibility="{Binding IsResultPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
          <StackPanel>
            <TextBlock Margin="0,0,0,8"
                       FontFamily="Segoe UI"
                       FontSize="12"
                       Foreground="#FF475569"
                       Text="Translating..."
                       Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />

            <TextBlock FontFamily="Segoe UI"
                       FontSize="15"
                       Foreground="#FF0F172A"
                       Text="{Binding TranslatedText}"
                       TextWrapping="Wrap"
                       Visibility="{Binding HasTranslation, Converter={StaticResource BoolToVisibilityConverter}}" />

            <TextBlock FontFamily="Segoe UI"
                       FontSize="13"
                       Foreground="#FFB91C1C"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Border x:Name="CollapsedShell"
            Width="82"
            Height="82"
            Margin="12"
            Padding="12"
            Background="#FF111827"
            BorderBrush="#FF1F2937"
            BorderThickness="1"
            CornerRadius="41"
            Visibility="{Binding IsExpanded, Converter={StaticResource InverseBoolToVisibilityConverter}}"
            MouseLeftButtonDown="CollapsedShell_OnMouseLeftButtonDown">
      <Border.Effect>
        <DropShadowEffect BlurRadius="24"
                          Color="#3B0F172A"
                          Direction="270"
                          Opacity="0.32"
                          ShadowDepth="8" />
      </Border.Effect>

      <Button x:Name="ExpandButton"
              Width="58"
              Height="58"
              Background="#FFF8FAFC"
              BorderThickness="0"
              Click="ExpandButton_OnClick"
              Command="{Binding ExpandCommand}"
              Cursor="Hand"
              FontFamily="Segoe UI"
              FontSize="20"
              FontWeight="SemiBold"
              Foreground="#FF111827">
        <Button.Template>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="29">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Button.Template>
        <TextBlock Text="中" />
      </Button>
    </Border>
  </Grid>
</Window>
